# Public site URL (used in metadata, sitemap, robots, JSON-LD)
# Falls back to https://superdecor.ro defined in src/lib/site.ts
NEXT_PUBLIC_SITE_URL=https://superdecor.ro

# Contact form endpoint (e.g. Resend, Formspree, custom API route)
# CONTACT_FORM_ENDPOINT=
# RESEND_API_KEY=

# Optional Google verification (for Search Console)
# GOOGLE_SITE_VERIFICATION=

# Optional Google Tag Manager ID (if used in addition to Vercel Analytics)
# NEXT_PUBLIC_GTM_ID=
